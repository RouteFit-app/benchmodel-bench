      },
      "description": "Real regression reverted from petclinic commit 753d35c. Removes the guard rejecting a visit whose date is not in the future, so a visit can again be booked in the past.",
      "detection_hints": {
        "must_mention_any": [
          "isAfter",
          "getDate",
          "future",
          "past",
          "visit",
          "date",
          "validation",
          "rejectValue",
          "LocalDate"
        ]
      },
      "injection": {
        "find": "\t\tif (visit.getDate() != null && !visit.getDate().isAfter(LocalDate.now())) {\n\t\t\tresult.rejectValue(\"date\", \"typeMismatch.visitDate\");\n\t\t}\n",
        "replace_with": ""
      }
    },
    {
      "id": "BUG_003",
      "file": "Visit.java",
      "function": "Visit",
      "category": "inconsistent_default",
      "severity": "low",
      "security_relevant": false,
      "difficulty": "hard",
      "provenance": {
        "commit": "753d35c",
        "date": "2026-06-01",
        "message": "default a new visit to tomorrow (future), matching the validation rule",
        "commit_url": "https://github.com/spring-projects/spring-petclinic/commit/753d35c"
      },
      "description": "Real regression reverted from petclinic commit 753d35c. The default date for a new Visit reverts from tomorrow to today; combined with the future-only rule, a freshly created visit's own default date would no longer satisfy validation. The subtle half of the same feature revert.",
      "detection_hints": {
        "must_mention_any": [
          "plusDays",
          "LocalDate.now",
          "default",
          "tomorrow",
          "today",
          "visit",
          "future",
          "date"
        ]
      },
      "injection": {
        "find": "this.date = LocalDate.now().plusDays(1);",
        "replace_with": "this.date = LocalDate.now();"
      }
    }
