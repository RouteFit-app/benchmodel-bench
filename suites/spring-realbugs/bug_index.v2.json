          "validation",
          "max",
          "unbounded",
          "@Column",
          "30",
          "bound"
        ]
      },
      "injection": {
        "find": "\t@Column(length = 30)\n\t@Size(max = 30)\n\t@NotBlank\n\tprivate String firstName;\n\n\t@Column(length = 30)\n\t@Size(max = 30)\n\t@NotBlank\n\tprivate String lastName;",
        "replace_with": "\t@Column\n\t@NotBlank\n\tprivate String firstName;\n\n\t@Column\n\t@NotBlank\n\tprivate String lastName;"
      }
    },
